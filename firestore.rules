rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Consultation Validation ---
    function isValidMessage(data) {
      return data.userId == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.content is string &&
             data.content.size() <= 5000 &&
             data.timestamp is timestamp;
    }

    // --- Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId);
      allow update: if isOwner(userId) && isValidId(userId);
      
      match /consultations/{messageId} {
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow get: if isOwner(userId) && resource.data.userId == userId;
        allow create: if isOwner(userId) && isValidId(userId) && isValidMessage(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
